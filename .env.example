# Copy this file to .env.local and fill in values
# (No secrets needed for basic setup --- CoinGecko free tier works without API key)

# If you upgrade to CoinGecko Pro, add key here:
# VITE_COINGECKO_API_KEY=your_key_here

# Set this to your deployed CF Worker URL:
# VITE_WORKER_URL=https://bearmarketclock-api.your-subdomain.workers.dev
